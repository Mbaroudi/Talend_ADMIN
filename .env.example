# =============================================================================
# Talend_ADMIN — environment configuration
# Copy this file to `.env` and change every secret before any real deployment.
#   cp .env.example .env
# =============================================================================

# ----- PostgreSQL (shared metadata DB: TAC + Rundeck) -----
POSTGRES_USER=tac
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=tac
# A second database for Rundeck is created automatically by the init script.
RUNDECK_DB_NAME=rundeck

# ----- MinIO (Talend job artifacts / S3-compatible storage) -----
MINIO_ROOT_USER=tacadmin
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_BUCKET_JOBS=talend-jobs
MINIO_BUCKET_LOGS=talend-logs

# ----- Rundeck (orchestrator) -----
RUNDECK_ADMIN_USER=admin
RUNDECK_ADMIN_PASSWORD=change-me-rundeck
# External URL used to build links in the UI/emails. Match the published port.
RUNDECK_GRAILS_URL=http://localhost:4440
# NOTE: the admin password below is ALSO set in rundeck/etc/realm.properties
# (the source of truth Rundeck reads at boot). Keep the two in sync — the
# bootstrap job and the webhook handler authenticate with these credentials.

# ----- TAC Platform (Flask portal) -----
TAC_PLATFORM_SECRET_KEY=change-me-flask-secret
# Public base URLs the portal links to (host-side ports).
RUNDECK_PUBLIC_URL=http://localhost:4440
MINIO_CONSOLE_PUBLIC_URL=http://localhost:9001
NEXUS_PUBLIC_URL=http://localhost:8081
GRAFANA_PUBLIC_URL=http://localhost:3000
PROMETHEUS_PUBLIC_URL=http://localhost:9090

# ----- Webhook handler (Git -> build -> Rundeck) -----
# Shared secret used to verify GitHub/GitLab/Azure DevOps webhook signatures.
WEBHOOK_SECRET=change-me-webhook-secret
# Rundeck project and job name triggered when a Talend repo is pushed.
RUNDECK_PROJECT=talend
RUNDECK_TRIGGER_JOB=Build and Deploy Talend Job

# ----- Grafana -----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# ----- Talend runner -----
# SSH user Rundeck uses to dispatch job execution onto the runner node.
TALEND_RUNNER_USER=talend
